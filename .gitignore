.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript build info
*.tsbuildinfo

# Vercel
.vercel
